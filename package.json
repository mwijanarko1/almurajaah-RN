{
  "name": "expo-rn-template",
  "version": "1.0.0",
  "description": "A reusable React Native template using Expo with TypeScript, navigation, and best practices",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "eas build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint ."
  },
  "keywords": [
    "expo",
    "react-native",
    "template",
    "typescript",
    "navigation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mwijanarko1/Expo-RN-Template"
  },
  "packageManager": "bun@1.3.10",
  "license": "MIT",
  "dependencies": {
    "@expo/metro-runtime": "~5.0.0",
    "@tanstack/react-query": "^5.90.16",
    "eslint-config-expo": "~55.0.0",
    "expo": "^55.0.0",
    "expo-constants": "~55.0.0",
    "expo-linking": "~55.0.0",
    "expo-notifications": "~55.0.0",
    "expo-router": "~55.0.0",
    "expo-status-bar": "~55.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-web": "~0.21.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.0.0",
    "@types/react": "~19.2.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "typescript": "~5.9.3"
  },
  "private": false
}
