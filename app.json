{
  "expo": {
    "name": "Al Muraja'ah",
    "slug": "al-murajaah",
    "scheme": "almurajaah",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/Al Muraja'ah Logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/Al Muraja'ah Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4ebdd"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Al Muraja'ah Logo.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/Al Muraja'ah Logo.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
